@model IEnumerable<CircleUI.Data.Models.Component>

@{
    ViewData["Title"] = "Components";
    Layout = "_Layout";
}

<h1>Components</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Component</a>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Type</th>
            <th>Content</th>
            <th>Parent Id</th>
            <th>Page Id</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var component in Model)
        {
            <tr>
                <td>@component.Id</td>
                <td>@component.Type</td>
                <td>@component.Content</td>
                <td>@component.ParentId</td>
                <td>@component.PageId</td>
                <td>
                    <a asp-action="Details" asp-route-id="@component.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@component.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@component.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>