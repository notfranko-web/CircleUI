@model CircleUI.ViewModels.Component.ComponentDetailsViewModel

@{
    ViewData["Title"] = "Component Details";
}

<h1>Component Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Type</dt>
        <dd class="col-sm-10">@Model.Type</dd>

        <dt class="col-sm-2">Content</dt>
        <dd class="col-sm-10">@Model.Content</dd>

        <dt class="col-sm-2">Layout</dt>
        <dd class="col-sm-10">@Model.Layout</dd>

        <dt class="col-sm-2">Parent Id</dt>
        <dd class="col-sm-10">@Model.ParentId</dd>

        <dt class="col-sm-2">Page Id</dt>
        <dd class="col-sm-10">@Model.PageId</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
