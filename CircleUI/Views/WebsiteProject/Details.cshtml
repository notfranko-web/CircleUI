@model CircleUI.ViewModels.WebsiteProject.WebsiteProjectDetailsViewModel

@{
    ViewData["Title"] = "Website Project Details";
}

<h1>Website Project Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Name</dt>
        <dd class="col-sm-10">@Model.Name</dd>

        <dt class="col-sm-2">Description</dt>
        <dd class="col-sm-10">@Model.Description</dd>

        <dt class="col-sm-2">Domain</dt>
        <dd class="col-sm-10">@Model.Domain</dd>

        <dt class="col-sm-2">Published</dt>
        <dd class="col-sm-10">@(Model.IsPublished ? "Yes" : "No")</dd>

        <dt class="col-sm-2">User Id</dt>
        <dd class="col-sm-10">@Model.UserId</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
