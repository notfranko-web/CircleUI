@model CircleUI.Core.DTOs.PageDTO
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title – Preview</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    @{
        var project = (CircleUI.Core.DTOs.WebsiteProjectDTO)ViewBag.Project;
    }
    @if (project != null)
    {
        <style>
            :root {
                --project-bg-color: @project.BackgroundColor;
                --project-primary-text-color: @project.PrimaryTextColor;
                --project-secondary-text-color: @project.SecondaryTextColor;
                --project-button-color: @project.ButtonColor;
                --project-button-text-color: @project.ButtonTextColor;
            }

            body {
                background-color: var(--project-bg-color) !important;
                color: var(--project-primary-text-color) !important;
            }

            h1, h2, h3, h4, h5, h6, p, span:not(.badge), div:not(.carousel) {
                color: var(--project-primary-text-color);
            }

            .text-muted {
                color: var(--project-secondary-text-color) !important;
            }

            .btn-primary,
            button:not(.carousel-control-prev):not(.carousel-control-next):not(.navbar-toggler):not(.btn-link):not(.btn-close) {
                background-color: var(--project-button-color) !important;
                border-color: var(--project-button-color) !important;
                color: var(--project-button-text-color) !important;
            }
        </style>
    }
    <style>
        body { padding-top: 48px; }
        #preview-bar {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 48px;
            background: #212529;
            color: #fff;
            display: flex;
            align-items: center;
            padding: 0 1rem;
            gap: 1rem;
            z-index: 9999;
            font-size: .875rem;
        }
        #preview-bar span { opacity: .6; }
    </style>
</head>
<body>
    <div id="preview-bar">
        <button onclick="window.close()" class="btn btn-sm btn-outline-light py-0">&#8592; Close Preview</button>
        <span>Previewing: <strong>@Model.Title</strong></span>
    </div>

    @foreach (var section in Model.SectionDtos)
    {
        <section class="section-container">
            @foreach (var component in section.ComponentDTOs)
            {
                @Html.Raw(component.Content)
            }
        </section>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
