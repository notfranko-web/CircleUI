@model CircleUI.Core.DTOs.PageDTO
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title – Preview</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <style>
        body { padding-top: 48px; }
        #preview-bar {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 48px;
            background: #212529;
            color: #fff;
            display: flex;
            align-items: center;
            padding: 0 1rem;
            gap: 1rem;
            z-index: 9999;
            font-size: .875rem;
        }
        #preview-bar span { opacity: .6; }
    </style>
</head>
<body>
    <div id="preview-bar">
        <button onclick="window.close()" class="btn btn-sm btn-outline-light py-0">&#8592; Close Preview</button>
        <span>Previewing: <strong>@Model.Title</strong></span>
    </div>

    @foreach (var section in Model.SectionDtos)
    {
        <section>
            @foreach (var component in section.ComponentDTOs)
            {
                @Html.Raw(component.Content)
            }
        </section>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
