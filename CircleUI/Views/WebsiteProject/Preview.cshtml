@model CircleUI.Core.DTOs.PageDTO
@{
    Layout = null;

    var project = ViewBag.Project as CircleUI.Core.DTOs.WebsiteProjectDTO;

    var bgColor     = !string.IsNullOrEmpty(project?.BackgroundColor)     ? project.BackgroundColor     : "#ffffff";
    var bgImage     = !string.IsNullOrEmpty(project?.BackgroundImage)     ? project.BackgroundImage     : null;
    var primaryText = !string.IsNullOrEmpty(project?.PrimaryTextColor)    ? project.PrimaryTextColor    : "#000000";
    var secondaryText = !string.IsNullOrEmpty(project?.SecondaryTextColor) ? project.SecondaryTextColor : "#6c757d";
    var btnColor    = !string.IsNullOrEmpty(project?.ButtonColor)         ? project.ButtonColor         : "#0d6efd";
    var btnTextColor = !string.IsNullOrEmpty(project?.ButtonTextColor)    ? project.ButtonTextColor     : "#ffffff";

    // Build background CSS as a C# string to avoid Razor encoding issues in <style> blocks
    var bgCss = bgImage != null
        ? $"background-color: transparent; background-image: url('{bgImage}'); background-size: cover; background-position: center top; background-repeat: no-repeat; background-attachment: fixed;"
        : $"background-color: {bgColor};";
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@Model.Title – Preview</title>
    <link rel="stylesheet" href="~/lib/bootstrap/css/bootstrap.min.css" />
    <style>
        html, body {
            margin: 0;
            padding: 0;
            min-height: 100vh;
        }
        html {
            @Html.Raw(bgCss)
        }
        body {
            padding-top: 48px;
            color: @primaryText;
            background: transparent;
        }
        h1, h2, h3, h4, h5, h6, p, span:not(.badge), div:not(.carousel) {
            color: @primaryText;
        }
        .text-muted {
            color: @secondaryText !important;
        }
        .btn-primary,
        button:not(.carousel-control-prev):not(.carousel-control-next):not(.navbar-toggler):not(.btn-link):not(.btn-close) {
            background-color: @btnColor !important;
            border-color: @btnColor !important;
            color: @btnTextColor !important;
        }
        #preview-bar {
            position: fixed;
            top: 0; left: 0; right: 0;
            height: 48px;
            background: #212529;
            color: #fff;
            display: flex;
            align-items: center;
            padding: 0 1rem;
            gap: 1rem;
            z-index: 9999;
            font-size: .875rem;
        }
        #preview-bar span { opacity: .6; }
    </style>
</head>
<body style="@Html.Raw(bgCss)">
    <div id="preview-bar">
        <button onclick="window.close()" class="btn btn-sm btn-outline-light py-0">&#8592; Close Preview</button>
        <span>Previewing: <strong>@Model.Title</strong></span>
    </div>

    @{
        var previewProject = ViewBag.Project as CircleUI.Core.DTOs.WebsiteProjectDTO;
    }
    @if (previewProject?.HeaderSection != null)
    {
        <header>
            @foreach (var hc in previewProject.HeaderSection.ComponentDTOs)
            {
                @Html.Raw(hc.Content)
            }
        </header>
    }

    <main>
        @foreach (var section in Model.SectionDtos)
        {
            <section>
                @foreach (var component in section.ComponentDTOs)
                {
                    @Html.Raw(component.Content)
                }
            </section>
        }
    </main>

    @if (previewProject?.FooterSection != null)
    {
        <footer>
            @foreach (var fc in previewProject.FooterSection.ComponentDTOs)
            {
                @Html.Raw(fc.Content)
            }
        </footer>
    }

    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/js/bootstrap.bundle.min.js"></script>
</body>
</html>
