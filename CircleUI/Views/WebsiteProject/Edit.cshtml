@model CircleUI.ViewModels.WebsiteProject.WebsiteProjectUpdateViewModel

@{
    ViewData["Title"] = "Edit Project";
    Layout = "_Layout";
}

<h1>Edit Project</h1>

<div class="row">
    <div class="col-md-6">
        <form asp-action="Edit" method="post">
            @Html.AntiForgeryToken()
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="UserId" />
            <input type="hidden" asp-for="Description" />

            <div class="mb-3">
                <label asp-for="Name" class="form-label fw-semibold"></label>
                <input asp-for="Name" class="form-control" />
                <span asp-validation-for="Name" class="text-danger small"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Domain" class="form-label fw-semibold"></label>
                <input asp-for="Domain" class="form-control" placeholder="e.g. mysite.com" />
                <span asp-validation-for="Domain" class="text-danger small"></span>
            </div>

            <div class="mb-3 form-check">
                <input asp-for="IsPublished" class="form-check-input" type="checkbox" />
                <label asp-for="IsPublished" class="form-check-label">Published</label>
            </div>

            <div class="d-flex gap-2">
                <button type="submit" class="btn btn-primary">Save</button>
                <a asp-action="Index" class="btn btn-secondary">Cancel</a>
            </div>
        </form>
    </div>
</div>
