@model IEnumerable<CircleUI.Core.DTOs.WebsiteProjectDTO>

@{
    ViewData["Title"] = "Website Projects";
    Layout = "_Layout";
}

<h1>Website Projects</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Project</a>

<table class="table">
    <thead>
        <tr>
            <th>Name</th>
            <th>Domain</th>
            <th>Published</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Name</td>
                <td>@project.Domain</td>
                <td>@(project.IsPublished ? "Yes" : "No")</td>
                <td>
                    <a asp-action="Builder" asp-route-id="@project.Id" class="btn btn-sm btn-success">Builder</a>
                    <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-warning">Edit</a>
                    <form asp-action="Duplicate" asp-route-id="@project.Id" method="post" class="d-inline">
                        @Html.AntiForgeryToken()
                        <button type="submit" class="btn btn-sm btn-outline-secondary">Duplicate</button>
                    </form>
                    <a asp-action="Delete" asp-route-id="@project.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
