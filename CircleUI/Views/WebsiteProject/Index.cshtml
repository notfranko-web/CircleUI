@model IEnumerable<CircleUI.Data.Models.WebsiteProject>

@{
    ViewData["Title"] = "Website Projects";
    Layout = "_Layout";
}

<h1>Website Projects</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New Project</a>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Name</th>
            <th>Domain</th>
            <th>Published</th>
            <th>User Id</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var project in Model)
        {
            <tr>
                <td>@project.Id</td>
                <td>@project.Name</td>
                <td>@project.Domain</td>
                <td>@(project.IsPublished ? "Yes" : "No")</td>
                <td>@project.UserId</td>
                <td>
                    <a asp-action="Details" asp-route-id="@project.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@project.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@project.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
