@model CircleUI.ViewModels.WebsiteProject.WebsiteProjectBuilderViewModel

@Html.AntiForgeryToken()
<h1>Build Project </h1>
<div class="row">
    
    <div class="col-2 border-end">
        <ul class="nav nav-pills nav-fill mb-3" id="sidebarTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active py-1 small" id="components-tab" data-bs-toggle="tab" data-bs-target="#components-sidebar" type="button" role="tab">Components</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link py-1 small" id="assets-tab" data-bs-toggle="tab" data-bs-target="#assets-sidebar" type="button" role="tab">Assets</button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="components-sidebar" role="tabpanel">
                <div class="components-sidebar p-2">
                    <div class="accordion accordion-flush" id="componentAccordion">
                        @{
                            var categories = Model.ComponentDtos.GroupBy(c => c.Category).ToList();
                            var catIndex = 0;
                        }
                        @foreach (var group in categories)
                        {
                            var collapseId = $"cat-collapse-{catIndex}";
                            var headingId  = $"cat-heading-{catIndex}";
                            catIndex++;
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="@headingId">
                                    <button class="accordion-button collapsed py-2 small fw-semibold"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#@collapseId"
                                            aria-expanded="false"
                                            aria-controls="@collapseId">
                                        @group.Key
                                    </button>
                                </h2>
                                <div id="@collapseId"
                                     class="accordion-collapse collapse"
                                     aria-labelledby="@headingId"
                                     data-bs-parent="#componentAccordion">
                                    <div class="accordion-body p-2 d-flex flex-column gap-2">
                                        @foreach (var component in group)
                                        {
                                            <div class="component-card p-2 border rounded bg-white"
                                                 draggable="true"
                                                 data-component-id="@component.Id"
                                                 style="cursor: grab;">
                                                <div class="small fw-bold text-muted mb-1">@component.Type</div>
                                                <div class="component-preview small overflow-hidden" style="max-height:60px;pointer-events:none;">
                                                    @Html.Raw(component.Content)
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="assets-sidebar" role="tabpanel">
                <div class="p-2">
                    <div class="mb-3">
                        <label for="assetUploadInput" class="form-label small fw-bold">Upload Photo</label>
                        <input class="form-control form-control-sm" type="file" id="assetUploadInput" accept="image/*">
                        <div id="uploadProgress" class="progress mt-2 d-none" style="height: 5px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                        </div>
                    </div>
                    <hr />
                    <div id="assetList" class="d-flex flex-wrap gap-2">
                        <!-- Assets will be loaded here -->
                        <div class="text-muted small text-center w-100 py-3">Loading assets...</div>
                    </div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-10 border">
        <h2>Pages</h2>

        <!-- Nav tabs -->
        <ul class="nav nav-tabs" id="pageTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active"
                        id="home-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#home"
                        type="button"
                        role="tab">
                    Instruction
                </button>
            </li>

            @foreach (var page1 in Model.PageDtos)
            {
                <li class="nav-item d-flex align-items-center" role="presentation">
                    <button class="nav-link"
                            id="tab-@page1.Id"
                            data-bs-toggle="tab"
                            data-bs-target="#pane-@page1.Id"
                            type="button"
                            role="tab">
                        @page1.Title
                    </button>
                    <form asp-controller="Page" asp-action="DeleteFromBuilder" method="post" class="page-delete-form d-inline">
                        <input type="hidden" name="pageId" value="@page1.Id" />
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <button type="submit" class="btn btn-link text-danger p-0 ms-1" title="Remove page"
                                onclick="return confirm('Delete page \'@page1.Title\'?')">&times;</button>
                    </form>
                </li>
            }
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link add-page-btn" title="Add page"
                        data-bs-toggle="modal" data-bs-target="#addPageModal">+ Add Page</button>
            </li>
        </ul>

        @if (TempData["PageError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
                @TempData["PageError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Add Page Modal -->
        <div class="modal fade" id="addPageModal" tabindex="-1" aria-labelledby="addPageModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form asp-controller="Page" asp-action="CreateForBuilder" method="post">
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <div class="modal-header">
                            <h5 class="modal-title" id="addPageModalLabel">New Page</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="pageTitle" class="form-label">Page Title</label>
                                <input type="text" class="form-control" id="pageTitle" name="title"
                                       placeholder="e.g. About Us" required autofocus />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Create Page</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tab content -->
        <div class="tab-content mt-3" id="pageTabsContent">
            <div id="home"
                 class="tab-pane fade show active"
                 role="tabpanel">
                <h3>HOME</h3>
                <p>instructions for working.</p>
            </div>

            @foreach (var page2 in Model.PageDtos)
            {
                <div id="pane-@page2.Id"
                     class="tab-pane fade"
                     role="tabpanel">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">@page2.Title</h3>
                        <a href="@Url.Action("Preview", "WebsiteProject", new { id = Model.Id, pageId = page2.Id })"
                           target="_blank"
                           class="btn btn-sm btn-outline-primary">Preview</a>
                    </div>
                    <div class="text-muted small">@page2.Path</div>
                    
                    <div class="d-flex flex-column gap-3 mt-2">
                        @foreach (var section1 in page2.SectionDtos)
                        {
                            <div class="border rounded p-3 bg-light section-drop-zone"
                                 data-section-id="@section1.Id">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <button class="btn btn-sm btn-link p-0 text-decoration-none collapse-section-btn" 
                                                type="button" 
                                                data-bs-toggle="collapse" 
                                                data-bs-target="#section-content-@section1.Id" 
                                                aria-expanded="true" 
                                                aria-controls="section-content-@section1.Id">
                                            <i class="bi bi-chevron-down"></i>
                                        </button>
                                        <span class="fw-semibold">@section1.Name</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-muted small font-monospace">@section1.HTMLId</span>
                                        <form asp-controller="Section" asp-action="RemoveFromPage" method="post" class="d-inline">
                                            <input type="hidden" name="sectionId" value="@section1.Id" />
                                            <input type="hidden" name="pageId" value="@page2.Id" />
                                            <input type="hidden" name="projectId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Remove section"
                                                    onclick="return confirm('Remove section \'@section1.Name\'?')">&times;</button>
                                        </form>
                                    </div>
                                </div>
                                
                                <div id="section-content-@section1.Id" class="collapse show">
                                    @if (!string.IsNullOrEmpty(section1.CSSClass))
                                    {
                                        <div class="text-muted small mb-2">CSS: @section1.CSSClass</div>
                                    }
                                    <div class="section-components d-flex flex-column gap-2 mt-2">
                                        @if (section1.ComponentDTOs.Any())
                                        {
                                            @foreach (var component2 in section1.ComponentDTOs)
                                            {
                                                <div class="border rounded p-2 bg-white small component-instance"
                                                     data-sc-id="@component2.SectionComponentId">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <span class="badge bg-secondary">@component2.Type</span>
                                                        <button type="button" class="btn btn-link text-danger p-0 remove-component-btn" title="Remove component">&times;</button>
                                                    </div>
                                                    <div class="component-editable"
                                                         data-component-id="@component2.Id">
                                                        @Html.Raw(component2.Content)
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="drop-placeholder text-muted small fst-italic p-2 text-center border border-dashed rounded">
                                                Drop a component here
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                            data-bs-toggle="modal" data-bs-target="#addSectionModal-@page2.Id">
                        + Add Section
                    </button>
                </div>

                <!-- Add Section Modal for page @page2.Id -->
                <div class="modal fade" id="addSectionModal-@page2.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-controller="Section" asp-action="AddToPage" method="post">
                                <input type="hidden" name="pageId" value="@page2.Id" />
                                <input type="hidden" name="projectId" value="@Model.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">New Section</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Section Name</label>
                                        <input type="text" class="form-control" name="name"
                                               placeholder="e.g. Hero" required autofocus />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Create Section</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Image Select Modal -->
<div class="modal fade" id="imageSelectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Select Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="modalAssetUploadInput" class="form-label fw-bold">Upload New Photo</label>
                    <input class="form-control" type="file" id="modalAssetUploadInput" accept="image/*">
                </div>
                <hr />
                <h6>Your Gallery</h6>
                <div id="modalAssetList" class="d-flex flex-wrap gap-3 mt-3">
                    <!-- Assets will be loaded here -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Image Lightbox Modal -->
<div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark border-0">
            <div class="modal-body p-0 text-center position-relative">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <img id="lightboxImage" src="" class="img-fluid" style="max-height: 80vh;">
                <div class="p-3 text-white bg-black bg-opacity-75">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span id="lightboxCaption" class="small"></span>
                        <div class="d-flex gap-2">
                             <button type="button" class="btn btn-sm btn-outline-light" id="changeImageBtn">Change Photo</button>
                             <button type="button" class="btn btn-sm btn-primary" id="saveResizeBtn">Apply Size</button>
                        </div>
                    </div>
                    <div class="row align-items-center g-2">
                        <div class="col-auto"><small>Width</small></div>
                        <div class="col">
                            <input type="range" class="form-range" id="imageWidthRange" min="10" max="100" step="1">
                        </div>
                        <div class="col-auto text-end" style="min-width: 45px;"><small id="imageWidthVal">100%</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .section-drop-zone.drag-over {
        outline: 2px dashed #0d6efd;
        background-color: #e9f0ff !important;
    }
    .border-dashed { border-style: dashed !important; }
    [data-text-editable]:focus { outline: 2px solid #0d6efd; border-radius: 2px; }
    [data-text-editable]:hover { outline: 1px dashed #adb5bd; border-radius: 2px; cursor: text; }
    .component-editable {
        min-height: 50px;
        position: relative;
    }
    .nav-link:not(.active) ~ .page-delete-form { display: none !important; }
    
    .asset-item-container { position: relative; display: inline-block; }
    .asset-item { width: 60px; height: 60px; object-fit: cover; cursor: pointer; border: 2px solid transparent; border-radius: 4px; transition: border-color 0.2s, transform 0.2s, outline 0.2s; }
    .modal-asset-item { width: 120px; height: 120px; object-fit: cover; cursor: pointer; border: 3px solid transparent; border-radius: 8px; transition: transform 0.2s, border-color 0.2s, outline 0.2s; }
    
    .delete-asset-btn { 
        position: absolute; top: -5px; right: -5px; 
        width: 18px; height: 18px; line-height: 16px; 
        font-size: 12px; padding: 0; border-radius: 50%; 
        display: none; z-index: 5;
    }
    .asset-item-container:hover .delete-asset-btn { display: block; }
    
    .component-editable img:hover { outline: 3px solid #0d6efd; transform: scale(1.01); }
    .asset-item:hover, .modal-asset-item:hover { transform: scale(1.05); outline: 3px solid #0d6efd; border-color: transparent; }

    #lightboxImage { cursor: zoom-out; }
</style>

<script>
    // Restore active tab from query string or model
    window.addEventListener('DOMContentLoaded', () => {
        const params = new URLSearchParams(window.location.search);
        let activeTab = params.get('activeTab') || '@Html.Raw(Model.ActiveTab)';
        console.log("Activating tab:", activeTab);
        if (activeTab && activeTab !== 'home' && activeTab !== 'pane-') {
            const triggerEl = document.querySelector(`[data-bs-target="#${activeTab}"]`);
            if (triggerEl) {
                console.log("Found trigger for tab:", activeTab);
                // Ensure the button is clicked to trigger Bootstrap's internal state management
                triggerEl.click();
            } else {
                console.warn("Could not find trigger for tab:", activeTab);
            }
        }
        
        // Ensure assets are loaded on start
        loadAssets();
    });

    // Drag source tracking
    let draggedComponentId = null;
    let draggedAssetPath = null;

    document.addEventListener('dragstart', e => {
        const card = e.target.closest('.component-card[draggable]');
        if (card) {
            draggedComponentId = card.dataset.componentId;
            e.dataTransfer.effectAllowed = 'copy';
            console.log("Drag started (component):", draggedComponentId);
            return;
        }

        const asset = e.target.closest('.asset-item[draggable]');
        if (asset) {
            draggedAssetPath = asset.dataset.path;
            e.dataTransfer.effectAllowed = 'copy';
            console.log("Drag started (asset):", draggedAssetPath);
        }
    });

    document.addEventListener('dragend', e => {
        draggedComponentId = null;
        draggedAssetPath = null;
        console.log("Drag ended");
    });

    document.addEventListener('dragover', e => {
        const zone = e.target.closest('.section-drop-zone');
        if (zone) {
            e.preventDefault();
            e.dataTransfer.dropEffect = 'copy';
            zone.classList.add('drag-over');
        }
    });

    document.addEventListener('dragleave', e => {
        const zone = e.target.closest('.section-drop-zone');
        if (zone && !zone.contains(e.relatedTarget)) {
            zone.classList.remove('drag-over');
        }
    });

    document.addEventListener('drop', async e => {
        const zone = e.target.closest('.section-drop-zone');
        if (zone) {
            e.preventDefault();
            zone.classList.remove('drag-over');
            
            if (!draggedComponentId && !draggedAssetPath) return;

            const sectionId = zone.dataset.sectionId;
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenInput) {
                console.error("Anti-forgery token not found.");
                return;
            }

            let res;
            if (draggedComponentId) {
                console.log("Drop component:", draggedComponentId, "to section:", sectionId);
                res = await fetch('/Section/AddComponent', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': tokenInput.value
                    },
                    body: `sectionId=${encodeURIComponent(sectionId)}&componentId=${encodeURIComponent(draggedComponentId)}`
                });
            } else if (draggedAssetPath) {
                console.log("Drop asset:", draggedAssetPath, "to section:", sectionId);
                res = await fetch('/Section/AddImageComponent', {
                    method: 'POST',
                    headers: { 
                        'Content-Type': 'application/x-www-form-urlencoded',
                        'RequestVerificationToken': tokenInput.value
                    },
                    body: `sectionId=${encodeURIComponent(sectionId)}&imageUrl=${encodeURIComponent(draggedAssetPath)}`
                });
            }
            if (!res.ok) {
                console.error("Fetch failed with status:", res.status);
                return;
            }
            const data = await res.json();
            console.log("Component added result:", data);
            if (!data.success) {
                console.error("Component addition failed:", data.message);
                return;
            }

            const container = zone.querySelector('.section-components');

            // Remove placeholder if present
            const placeholder = container.querySelector('.drop-placeholder');
            if (placeholder) placeholder.remove();

            const el = document.createElement('div');
            el.className = 'border rounded p-2 bg-white small component-instance';
            el.dataset.scId = data.sectionComponentId;

            const header = document.createElement('div');
            header.className = 'd-flex justify-content-between align-items-center mb-1';
            header.innerHTML = `<span class="badge bg-secondary">${data.type}</span>`;
            const removeBtn = document.createElement('button');
            removeBtn.type = 'button';
            removeBtn.className = 'btn btn-link text-danger p-0 remove-component-btn';
            removeBtn.title = 'Remove component';
            removeBtn.textContent = '×';
            header.appendChild(removeBtn);
            el.appendChild(header);

            const contentDiv = document.createElement('div');
            contentDiv.className = 'component-editable';
            contentDiv.dataset.componentId = data.componentId;
            contentDiv.innerHTML = data.content;

            el.appendChild(contentDiv);
            container.appendChild(el);
            
            if (contentDiv.querySelector('.carousel')) {
                const carousels = contentDiv.querySelectorAll('.carousel');
                carousels.forEach(c => {
                    new bootstrap.Carousel(c);
                });
            }

            activateComponentEditing(contentDiv);
            console.log("New component element added and activated.");
        }
    });

    function activateComponentEditing(containerEl) {
        if (!containerEl) return;
        if (containerEl.dataset.editingActivated) return;
        containerEl.dataset.editingActivated = 'true';

        console.log("Activating editing for container:", containerEl);
        
        // Skip editing activation for carousels to avoid breaking their structure
        if (containerEl.querySelector('.carousel')) {
             console.log("Skipping editing activation for carousel container");
             return;
        }

        containerEl.querySelectorAll('[data-text-editable]').forEach(el => {
            el.removeAttribute('contenteditable');
            el.removeAttribute('spellcheck');
            el.removeAttribute('data-text-editable');
        });

        // Remove browser contenteditable artifacts (e.g. trailing <div><br></div>).
        containerEl.querySelectorAll('div').forEach(el => {
            if (el.innerHTML.trim() === '' || el.innerHTML.trim() === '<br>') el.remove();
        });

        const componentId = containerEl.dataset.componentId;
        const walker = document.createTreeWalker(containerEl, NodeFilter.SHOW_TEXT);
        const seen = new Set();
        let node;
        while ((node = walker.nextNode())) {
            if (!node.textContent.trim()) continue;
            const parent = node.parentElement;
            if (!parent || parent === containerEl || seen.has(parent)) continue;
            
            // If parent is an <a> tag, we might want to make it editable too, but carefully
            // If parent is an <img> (which shouldn't have text nodes anyway, but just in case)
            if (parent.tagName === 'IMG' || parent.closest('img')) continue;

            seen.add(parent);
            parent.contentEditable = 'true';
            parent.spellcheck = false;
            parent.setAttribute('data-text-editable', '');
        }
        
        wireImagesInContainer(containerEl);
    }

    document.addEventListener('blur', async e => {
        const editable = e.target.closest('[data-text-editable]');
        if (editable) {
            const containerEl = editable.closest('.component-editable');
            if (!containerEl) return;
            const componentId = containerEl.dataset.componentId;

            const clone = containerEl.cloneNode(true);
            clone.querySelectorAll('[data-text-editable]').forEach(el => {
                el.removeAttribute('contenteditable');
                el.removeAttribute('spellcheck');
                el.removeAttribute('data-text-editable');
                el.removeAttribute('data-editing-activated');
            });
            clone.querySelectorAll('img').forEach(img => {
                // Keep the style attribute for width/height preservation
                img.removeAttribute('contenteditable');
                img.removeAttribute('draggable');
            });
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenInput) {
                console.warn("Anti-forgery token not found for content update.");
                return;
            }

            console.log("Saving content for component:", componentId);
            const body = `componentId=${encodeURIComponent(componentId)}&content=${encodeURIComponent(clone.innerHTML)}`;
            console.log("Save payload length:", body.length);
            const res = await fetch('/Section/UpdateComponentContent', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': tokenInput.value
                },
                body: body
            });
            if (!res.ok) {
                console.error("Content update failed with status:", res.status);
            } else {
                console.log("Content saved successfully.");
            }
        }
    }, true);

    document.addEventListener('click', async e => {
        const btn = e.target.closest('.remove-component-btn');
        if (btn) {
            const instance = btn.closest('.component-instance');
            const scId = instance.dataset.scId;
            console.log("Removing component instance:", scId);
            const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
            if (!tokenInput) {
                console.warn("Anti-forgery token not found for removal.");
                return;
            }
            const res = await fetch('/Section/RemoveComponent', {
                method: 'POST',
                headers: { 
                    'Content-Type': 'application/x-www-form-urlencoded',
                    'RequestVerificationToken': tokenInput.value
                },
                body: `sectionComponentId=${encodeURIComponent(scId)}`
            });
            if (!res.ok) {
                console.error("Removal failed with status:", res.status);
                return;
            }
            const json = await res.json();
            console.log("Removal result:", json);
            if (json.success) {
                const container = instance.closest('.section-components');
                instance.remove();
                if (!container.querySelector('.component-instance')) {
                    container.innerHTML = '<div class="drop-placeholder text-muted small fst-italic p-2 text-center border border-dashed rounded">Drop a component here</div>';
                }
            }
        }
    });

    document.querySelectorAll('.component-editable').forEach(activateComponentEditing);

    // Asset Management
    async function loadAssets() {
        console.log("Loading assets...");
        const res = await fetch('/Asset/GetMyAssets');
        if (!res.ok) {
            console.error("Failed to load assets:", res.status);
            return;
        }
        const assets = await res.json();
        console.log("Assets loaded:", assets.length);
        
        const assetList = document.getElementById('assetList');
        const modalAssetList = document.getElementById('modalAssetList');
        
        const html = assets.map(a => `
            <div class="asset-item-container">
                <img src="${a.storagePath}" class="asset-item img-fluid rounded" title="${a.fileName}" data-path="${a.storagePath}" draggable="true">
                <button class="btn btn-danger btn-sm delete-asset-btn" onclick="deleteAsset('${a.id}', event)">×</button>
            </div>`).join('');
        const modalHtml = assets.map(a => `
            <div class="asset-item-container">
                <img src="${a.storagePath}" class="modal-asset-item img-fluid rounded" title="${a.fileName}" data-path="${a.storagePath}">
                <button class="btn btn-danger btn-sm delete-asset-btn" onclick="deleteAsset('${a.id}', event)">×</button>
            </div>`).join('');
        
        if (assetList) assetList.innerHTML = html || '<div class="text-muted small w-100 text-center py-2">No photos uploaded.</div>';
        if (modalAssetList) modalAssetList.innerHTML = modalHtml || '<div class="text-muted small w-100 text-center py-2">No photos uploaded.</div>';
    }

    async function deleteAsset(assetId, event) {
        if (event) {
            event.preventDefault();
            event.stopPropagation();
        }
        if (!confirm('Are you sure you want to delete this asset?')) return;

        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        try {
            const res = await fetch(`/Asset/Delete/${assetId}`, {
                method: 'POST',
                headers: { 'RequestVerificationToken': tokenInput.value }
            });
            const json = await res.json();
            if (json.success) {
                await loadAssets();
            } else {
                alert(json.message || "Delete failed");
            }
        } catch (err) {
            console.error(err);
        }
    }

    async function uploadFile(file, isModal = false) {
        const progress = document.getElementById('uploadProgress');
        if (progress && !isModal) progress.classList.remove('d-none');
        
        const formData = new FormData();
        formData.append('file', file);
        
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        
        try {
            const res = await fetch('/Asset/Upload', {
                method: 'POST',
                headers: { 'RequestVerificationToken': tokenInput.value },
                body: formData
            });
            const json = await res.json();
            if (json.success) {
                await loadAssets();
            } else {
                alert(json.message || "Upload failed");
            }
        } catch (err) {
            console.error(err);
        } finally {
            if (progress && !isModal) progress.classList.add('d-none');
        }
    }

    document.getElementById('assetUploadInput').addEventListener('change', e => {
        if (e.target.files.length > 0) uploadFile(e.target.files[0]);
    });
    
    document.getElementById('modalAssetUploadInput').addEventListener('change', e => {
        if (e.target.files.length > 0) uploadFile(e.target.files[0], true);
    });

    // ─── Image Lightbox ───────────────────────────────────────────────────────
    // Lazy modal accessors — safe to call before Bootstrap has initialised.
    let activeImageElement = null;
    function getLightboxModal()    { return bootstrap.Modal.getOrCreateInstance(document.getElementById('lightboxModal')); }
    function getImageSelectModal() { return bootstrap.Modal.getOrCreateInstance(document.getElementById('imageSelectModal')); }

    function openLightbox(img, isComponentImg) {
        activeImageElement = isComponentImg ? img : null;

        const lbImg    = document.getElementById('lightboxImage');
        const range    = document.getElementById('imageWidthRange');
        const rangeVal = document.getElementById('imageWidthVal');
        const saveBtn  = document.getElementById('saveResizeBtn');
        const chgBtn   = document.getElementById('changeImageBtn');

        lbImg.src = img.src;
        document.getElementById('lightboxCaption').textContent = img.title || img.alt || 'Image Preview';
        lbImg.style.maxHeight  = '80vh';
        lbImg.style.height     = 'auto';
        lbImg.style.width      = 'auto';
        lbImg.style.objectFit  = 'contain';
        lbImg.classList.add('d-block', 'mx-auto');

        if (isComponentImg) {
            const w = parseInt(img.style.maxWidth || img.style.width) || 50;
            range.value = w;
            rangeVal.textContent = w + '%';
            lbImg.style.maxWidth = w + '%';
            saveBtn.classList.remove('d-none');
            chgBtn.classList.remove('d-none');
        } else {
            lbImg.style.maxWidth = '100%';
            saveBtn.classList.add('d-none');
            chgBtn.classList.add('d-none');
        }

        getLightboxModal().show();
    }

    // Wire every <img> inside a .component-editable to open the lightbox.
    // Uses .onclick (property assignment) — always overwrites cleanly, never stacks.
    function wireImagesInContainer(containerEl) {
        containerEl.querySelectorAll('img').forEach(function(img) {
            img.contentEditable = 'false';
            img.setAttribute('draggable', 'false');
            img.style.cursor = 'pointer';
            img.onclick = function(e) {
                e.preventDefault();
                e.stopPropagation();
                openLightbox(this, true);
            };
        });
    }

    // Width slider
    document.getElementById('imageWidthRange').addEventListener('input', function() {
        document.getElementById('lightboxImage').style.maxWidth = this.value + '%';
        document.getElementById('imageWidthVal').textContent = this.value + '%';
    });

    // Apply size
    document.getElementById('saveResizeBtn').addEventListener('click', function() {
        if (!activeImageElement) return;
        const w = document.getElementById('imageWidthRange').value + '%';
        activeImageElement.style.maxWidth   = w;
        activeImageElement.style.width      = 'auto';
        activeImageElement.style.height     = 'auto';
        activeImageElement.style.objectFit  = 'contain';
        activeImageElement.classList.add('d-block', 'mx-auto');
        saveComponentContent(activeImageElement.closest('.component-editable'));
        getLightboxModal().hide();
    });

    // Change photo
    document.getElementById('changeImageBtn').addEventListener('click', function() {
        getLightboxModal().hide();
        getImageSelectModal().show();
    });

    // Click lightbox image to close
    document.getElementById('lightboxImage').addEventListener('click', function() {
        getLightboxModal().hide();
    });

    // Sidebar asset or modal gallery: click to preview / select
    document.addEventListener('click', function(e) {
        if (e.target.closest('.remove-component-btn')) return;

        const modalAsset = e.target.closest('.modal-asset-item');
        if (modalAsset && activeImageElement) {
            activeImageElement.src = modalAsset.dataset.path;
            const container = activeImageElement.closest('.component-editable');
            if (container) saveComponentContent(container);
            getImageSelectModal().hide();
            e.preventDefault();
            e.stopPropagation();
            return;
        }

        const asset = e.target.closest('.asset-item') || e.target.closest('.modal-asset-item');
        if (asset) {
            e.preventDefault();
            e.stopPropagation();
            openLightbox(asset, false);
        }
    });

    async function saveComponentContent(containerEl) {
        if (!containerEl) return;
        const componentId = containerEl.dataset.componentId;
        const clone = containerEl.cloneNode(true);
        clone.querySelectorAll('[data-text-editable]').forEach(el => {
            el.removeAttribute('contenteditable');
            el.removeAttribute('spellcheck');
            el.removeAttribute('data-text-editable');
            el.removeAttribute('data-editing-activated');
        });
        clone.querySelectorAll('img').forEach(img => {
            img.removeAttribute('contenteditable');
            img.removeAttribute('draggable');
        });
        const tokenInput = document.querySelector('input[name="__RequestVerificationToken"]');
        const body = `componentId=${encodeURIComponent(componentId)}&content=${encodeURIComponent(clone.innerHTML)}`;
        
        await fetch('/Section/UpdateComponentContent', {
            method: 'POST',
            headers: { 
                'Content-Type': 'application/x-www-form-urlencoded',
                'RequestVerificationToken': tokenInput.value
            },
            body: body
        });
    }

    document.getElementById('assets-tab').addEventListener('shown.bs.tab', () => {
        console.log("Assets tab shown, reloading assets...");
        loadAssets();
    });

    // loadAssets(); // Removed from here, called in DOMContentLoaded
</script>