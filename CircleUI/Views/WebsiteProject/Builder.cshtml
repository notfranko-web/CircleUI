@model CircleUI.ViewModels.WebsiteProject.WebsiteProjectBuilderViewModel

@Html.AntiForgeryToken()

@{
    var builderBgColor = string.IsNullOrEmpty(Model.BackgroundColor) ? "#ffffff" : Model.BackgroundColor;
    var builderBgImage = string.IsNullOrEmpty(Model.BackgroundImage) ? null : Model.BackgroundImage;
    var builderPrimaryText = string.IsNullOrEmpty(Model.PrimaryTextColor) ? "#000000" : Model.PrimaryTextColor;
    var builderSecondaryText = string.IsNullOrEmpty(Model.SecondaryTextColor) ? "#6c757d" : Model.SecondaryTextColor;
    var builderBtnColor = string.IsNullOrEmpty(Model.ButtonColor) ? "#0d6efd" : Model.ButtonColor;
    var builderBtnTextColor = string.IsNullOrEmpty(Model.ButtonTextColor) ? "#ffffff" : Model.ButtonTextColor;
}
<style id="dynamic-theme">
    :root {
        --project-bg-color: @builderBgColor;
        --project-bg-image: @(builderBgImage == null ? "none" : $"url('{builderBgImage}')");
        --project-effective-bg-color: @(builderBgImage == null ? builderBgColor : "transparent");
        --project-primary-text-color: @builderPrimaryText;
        --project-secondary-text-color: @builderSecondaryText;
        --project-button-color: @builderBtnColor;
        --project-button-text-color: @builderBtnTextColor;
    }

    .page-tab-item.drag-over-tab > button.nav-link {
        outline: 2px dashed #6f42c1;
        outline-offset: -2px;
    }
    .page-tab-item .drag-handle { user-select: none; }
    .page-tab-item .rename-page-btn { display: none; }
    .page-tab-item:has(.nav-link.active) .rename-page-btn { display: inline; }
</style>

<div class="d-flex align-items-center justify-content-between mb-2">
    <h1 class="mb-0">Build Project</h1>
    <div class="d-flex align-items-center gap-2">
        @if (Model.IsPublished)
        {
            <a href="/sites/@Model.Id" target="_blank" class="btn btn-sm btn-outline-secondary">View Live Site</a>
            <button id="unpublish-btn" class="btn btn-sm btn-danger"
                    data-project-id="@Model.Id"
                    data-action="unpublish">Unpublish</button>
        }
        else
        {
            <button id="publish-btn" class="btn btn-sm btn-success"
                    data-project-id="@Model.Id"
                    data-action="publish">Publish</button>
        }
    </div>
</div>
<div class="row">
    
    <div class="col-2 border-end">
        <ul class="nav nav-pills nav-fill mb-3" id="sidebarTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active py-1 small" id="components-tab" data-bs-toggle="tab" data-bs-target="#components-sidebar" type="button" role="tab">Components</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link py-1 small" id="assets-tab" data-bs-toggle="tab" data-bs-target="#assets-sidebar" type="button" role="tab">Assets</button>
            </li>
            <li class="nav-item" role="presentation">
                <button class="nav-link py-1 small" id="theme-tab" data-bs-toggle="tab" data-bs-target="#theme-sidebar" type="button" role="tab">Theme</button>
            </li>
        </ul>

        <div class="tab-content">
            <div class="tab-pane fade show active" id="components-sidebar" role="tabpanel">
                <div class="components-sidebar p-2">
                    <div class="accordion accordion-flush" id="componentAccordion">
                        @{
                            var categories = Model.ComponentDtos.GroupBy(c => c.Category).ToList();
                            var catIndex = 0;
                        }
                        @foreach (var group in categories)
                        {
                            var collapseId = $"cat-collapse-{catIndex}";
                            var headingId  = $"cat-heading-{catIndex}";
                            catIndex++;
                            <div class="accordion-item">
                                <h2 class="accordion-header" id="@headingId">
                                    <button class="accordion-button collapsed py-2 small fw-semibold"
                                            type="button"
                                            data-bs-toggle="collapse"
                                            data-bs-target="#@collapseId"
                                            aria-expanded="false"
                                            aria-controls="@collapseId">
                                        @group.Key
                                    </button>
                                </h2>
                                <div id="@collapseId"
                                     class="accordion-collapse collapse"
                                     aria-labelledby="@headingId"
                                     data-bs-parent="#componentAccordion">
                                    <div class="accordion-body p-2 d-flex flex-column gap-2">
                                        @foreach (var component in group)
                                        {
                                            <div class="component-card p-2 border rounded"
                                                 draggable="true"
                                                 data-component-id="@component.Id"
                                                 style="cursor: grab;">
                                                <div class="small fw-bold text-muted mb-1">@component.Type</div>
                                                <div class="component-preview small overflow-hidden" style="max-height:60px;pointer-events:none;">
                                                    @Html.Raw(component.Content)
                                                </div>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="assets-sidebar" role="tabpanel">
                <div class="p-2">
                    <div class="mb-3">
                        <label for="assetUploadInput" class="form-label small fw-bold">Upload Photo</label>
                        <input class="form-control form-control-sm" type="file" id="assetUploadInput" accept="image/*">
                        <div id="uploadProgress" class="progress mt-2 d-none" style="height: 5px;">
                            <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                        </div>
                    </div>
                    <hr />
                    <div id="assetList" class="d-flex flex-wrap gap-2">
                        <!-- Assets will be loaded here -->
                        <div class="text-muted small text-center w-100 py-3">Loading assets...</div>
                    </div>
                </div>
            </div>
            <div class="tab-pane fade" id="theme-sidebar" role="tabpanel">
                <div class="p-3">
                    <h6 class="mb-3">Project Theme</h6>
                    <form id="themeForm">
                        <input type="hidden" id="themeProjectId" value="@Model.Id" />
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Background Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="backgroundColor" value="@builderBgColor" title="Choose background color">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Primary Text Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="primaryTextColor" value="@builderPrimaryText" title="Choose primary text color">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Secondary Text Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="secondaryTextColor" value="@builderSecondaryText" title="Choose secondary text color">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Button Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="buttonColor" value="@builderBtnColor" title="Choose button color">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Button Text Color</label>
                            <input type="color" class="form-control form-control-color w-100" id="buttonTextColor" value="@builderBtnTextColor" title="Choose button text color">
                        </div>
                        <div class="mb-3">
                            <label class="form-label small fw-bold">Background Image</label>
                            <div class="d-flex align-items-center gap-2 mb-2">
                                <div id="bgImagePreview" class="border rounded bg-light d-flex align-items-center justify-content-center" style="width: 50px; height: 50px; overflow: hidden;">
                                    @if (!string.IsNullOrEmpty(Model.BackgroundImage))
                                    {
                                        <img src="@Model.BackgroundImage" style="width: 100%; height: 100%; object-fit: cover;" />
                                    }
                                    else
                                    {
                                        <i class="bi bi-image text-muted"></i>
                                    }
                                </div>
                                <div class="flex-grow-1">
                                    <button type="button" class="btn btn-outline-secondary btn-sm w-100" id="selectBgImageBtn">Select Image</button>
                                </div>
                                <button type="button" class="btn btn-outline-danger btn-sm" id="removeBgImageBtn" title="Remove image">
                                    <i class="bi bi-x"></i>
                                </button>
                            </div>
                            <input type="hidden" id="backgroundImage" value="@Model.BackgroundImage" />
                        </div>
                        <button type="button" class="btn btn-primary btn-sm w-100" id="saveThemeBtn">Save Theme</button>
                    </form>
                    <div id="themeStatus" class="mt-2 small text-center d-none"></div>
                </div>
            </div>
        </div>
    </div>
    <div class="col-10 border">
        <h2>Pages</h2>

        <!-- Nav tabs -->
        <ul class="nav nav-tabs" id="pageTabs" role="tablist">
            <li class="nav-item" role="presentation">
                <button class="nav-link active"
                        id="home-tab"
                        data-bs-toggle="tab"
                        data-bs-target="#home"
                        type="button"
                        role="tab">
                    Instruction
                </button>
            </li>

            @foreach (var page1 in Model.PageDtos)
            {
                <li class="nav-item d-flex align-items-center page-tab-item"
                    role="presentation"
                    draggable="true"
                    data-page-id="@page1.Id">
                    <span class="drag-handle text-muted px-1" style="cursor:grab;font-size:.7rem;" title="Drag to reorder">⠿</span>
                    <button class="nav-link"
                            id="tab-@page1.Id"
                            data-bs-toggle="tab"
                            data-bs-target="#pane-@page1.Id"
                            type="button"
                            role="tab">
                        @page1.Title
                    </button>
                    <button type="button"
                            class="btn btn-link p-0 ms-1 rename-page-btn"
                            title="Rename page"
                            data-page-id="@page1.Id"
                            data-page-title="@page1.Title"
                            style="font-size:.75rem;line-height:1;">&#9998;</button>
                    <form asp-controller="Page" asp-action="DeleteFromBuilder" method="post" class="page-delete-form d-inline">
                        <input type="hidden" name="pageId" value="@page1.Id" />
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <button type="submit" class="btn btn-link text-danger p-0 ms-1" title="Remove page"
                                onclick="return confirm('Delete page \'@page1.Title\'?')">&times;</button>
                    </form>
                </li>
            }
            <li class="nav-item" role="presentation">
                <button type="button" class="nav-link add-page-btn" title="Add page"
                        data-bs-toggle="modal" data-bs-target="#addPageModal">+ Add Page</button>
            </li>
        </ul>

        @if (TempData["PageError"] != null)
        {
            <div class="alert alert-danger alert-dismissible fade show mt-2" role="alert">
                @TempData["PageError"]
                <button type="button" class="btn-close" data-bs-dismiss="alert" aria-label="Close"></button>
            </div>
        }

        <!-- Add Page Modal -->
        <div class="modal fade" id="addPageModal" tabindex="-1" aria-labelledby="addPageModalLabel" aria-hidden="true">
            <div class="modal-dialog">
                <div class="modal-content">
                    <form asp-controller="Page" asp-action="CreateForBuilder" method="post">
                        <input type="hidden" name="projectId" value="@Model.Id" />
                        <div class="modal-header">
                            <h5 class="modal-title" id="addPageModalLabel">New Page</h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                        </div>
                        <div class="modal-body">
                            <div class="mb-3">
                                <label for="pageTitle" class="form-label">Page Title</label>
                                <input type="text" class="form-control" id="pageTitle" name="title"
                                       placeholder="e.g. About Us" required autofocus />
                            </div>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="submit" class="btn btn-primary">Create Page</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>

        <!-- Tab content -->
        <div class="tab-content mt-3" id="pageTabsContent">
            <div id="home"
                 class="tab-pane fade show active"
                 role="tabpanel">
                <h3>HOME</h3>
                <p>instructions for working.</p>
            </div>

            @foreach (var page2 in Model.PageDtos)
            {
                <div id="pane-@page2.Id"
                     class="tab-pane fade"
                     role="tabpanel">
                    <div class="d-flex justify-content-between align-items-center">
                        <h3 class="mb-0">@page2.Title</h3>
                        <div class="d-flex gap-2">
                            <form asp-controller="Section" asp-action="DuplicatePage" method="post" class="d-inline">
                                @Html.AntiForgeryToken()
                                <input type="hidden" name="pageId" value="@page2.Id" />
                                <input type="hidden" name="projectId" value="@Model.Id" />
                                <button type="submit" class="btn btn-sm btn-outline-secondary">Duplicate Page</button>
                            </form>
                            <a href="@Url.Action("Preview", "WebsiteProject", new { id = Model.Id, pageId = page2.Id })"
                               target="_blank"
                               class="btn btn-sm btn-outline-primary">Preview</a>
                        </div>
                    </div>
                    <div class="text-muted small">@page2.Path</div>
                    
                    @* Global Header *@
                    @if (Model.HeaderSection != null)
                    {
                        <div class="border rounded p-3 mt-2 section-drop-zone global-section"
                             data-section-id="@Model.HeaderSection.Id"
                             style="border-color: rgba(139,92,246,.4) !important; background: rgba(139,92,246,.07);">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-semibold"><span class="badge bg-purple me-1" style="background:#6f42c1;">Global</span> Header</span>
                                <span class="text-muted small">Shared across all pages</span>
                            </div>
                            <div class="section-components d-flex flex-column gap-2">
                                @if (Model.HeaderSection.ComponentDTOs.Any())
                                {
                                    @foreach (var hc in Model.HeaderSection.ComponentDTOs)
                                    {
                                        <div class="border rounded p-2 small component-instance"
                                             data-sc-id="@hc.SectionComponentId">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="badge bg-secondary">@hc.Type</span>
                                                <button type="button" class="btn btn-link text-danger p-0 remove-component-btn" title="Remove component">&times;</button>
                                            </div>
                                            <div class="component-editable" data-component-id="@hc.Id">
                                                @Html.Raw(hc.Content)
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="drop-placeholder text-muted small fst-italic p-2 text-center border border-dashed rounded">
                                        Drop a component here
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <div class="d-flex flex-column gap-3 mt-2">
                        @foreach (var section1 in page2.SectionDtos)
                        {
                            <div class="border rounded p-3 bg-light section-drop-zone"
                                 data-section-id="@section1.Id">
                                <div class="d-flex justify-content-between align-items-center mb-2">
                                    <div class="d-flex align-items-center gap-2">
                                        <button class="btn btn-sm btn-link p-0 text-decoration-none collapse-section-btn" 
                                                type="button" 
                                                data-bs-toggle="collapse" 
                                                data-bs-target="#section-content-@section1.Id" 
                                                aria-expanded="true" 
                                                aria-controls="section-content-@section1.Id">
                                            <i class="bi bi-chevron-down"></i>
                                        </button>
                                        <span class="fw-semibold">@section1.Name</span>
                                    </div>
                                    <div class="d-flex align-items-center gap-2">
                                        <span class="text-muted small font-monospace">@section1.HTMLId</span>
                                        <form asp-controller="Section" asp-action="RemoveFromPage" method="post" class="d-inline">
                                            <input type="hidden" name="sectionId" value="@section1.Id" />
                                            <input type="hidden" name="pageId" value="@page2.Id" />
                                            <input type="hidden" name="projectId" value="@Model.Id" />
                                            <button type="submit" class="btn btn-sm btn-outline-danger py-0 px-1" title="Remove section"
                                                    onclick="return confirm('Remove section \'@section1.Name\'?')">&times;</button>
                                        </form>
                                    </div>
                                </div>
                                
                                <div id="section-content-@section1.Id" class="collapse show">
                                    @if (!string.IsNullOrEmpty(section1.CSSClass))
                                    {
                                        <div class="text-muted small mb-2">CSS: @section1.CSSClass</div>
                                    }
                                    <div class="section-components d-flex flex-column gap-2 mt-2">
                                        @if (section1.ComponentDTOs.Any())
                                        {
                                            @foreach (var component2 in section1.ComponentDTOs)
                                            {
                                                <div class="border rounded p-2 small component-instance"
                                                     data-sc-id="@component2.SectionComponentId">
                                                    <div class="d-flex justify-content-between align-items-center mb-1">
                                                        <span class="badge bg-secondary">@component2.Type</span>
                                                        <button type="button" class="btn btn-link text-danger p-0 remove-component-btn" title="Remove component">&times;</button>
                                                    </div>
                                                    <div class="component-editable"
                                                         data-component-id="@component2.Id">
                                                        @Html.Raw(component2.Content)
                                                    </div>
                                                </div>
                                            }
                                        }
                                        else
                                        {
                                            <div class="drop-placeholder text-muted small fst-italic p-2 text-center border border-dashed rounded">
                                                Drop a component here
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>
                        }
                    </div>

                    @* Global Footer *@
                    @if (Model.FooterSection != null)
                    {
                        <div class="border rounded p-3 mt-2 section-drop-zone global-section"
                             data-section-id="@Model.FooterSection.Id"
                             style="border-color: rgba(139,92,246,.4) !important; background: rgba(139,92,246,.07);">
                            <div class="d-flex justify-content-between align-items-center mb-2">
                                <span class="fw-semibold"><span class="badge me-1" style="background:#6f42c1;">Global</span> Footer</span>
                                <span class="text-muted small">Shared across all pages</span>
                            </div>
                            <div class="section-components d-flex flex-column gap-2">
                                @if (Model.FooterSection.ComponentDTOs.Any())
                                {
                                    @foreach (var fc in Model.FooterSection.ComponentDTOs)
                                    {
                                        <div class="border rounded p-2 small component-instance"
                                             data-sc-id="@fc.SectionComponentId">
                                            <div class="d-flex justify-content-between align-items-center mb-1">
                                                <span class="badge bg-secondary">@fc.Type</span>
                                                <button type="button" class="btn btn-link text-danger p-0 remove-component-btn" title="Remove component">&times;</button>
                                            </div>
                                            <div class="component-editable" data-component-id="@fc.Id">
                                                @Html.Raw(fc.Content)
                                            </div>
                                        </div>
                                    }
                                }
                                else
                                {
                                    <div class="drop-placeholder text-muted small fst-italic p-2 text-center border border-dashed rounded">
                                        Drop a component here
                                    </div>
                                }
                            </div>
                        </div>
                    }

                    <button type="button" class="btn btn-outline-secondary btn-sm mt-2"
                            data-bs-toggle="modal" data-bs-target="#addSectionModal-@page2.Id">
                        + Add Section
                    </button>
                </div>

                <!-- Add Section Modal for page @page2.Id -->
                <div class="modal fade" id="addSectionModal-@page2.Id" tabindex="-1" aria-hidden="true">
                    <div class="modal-dialog">
                        <div class="modal-content">
                            <form asp-controller="Section" asp-action="AddToPage" method="post">
                                <input type="hidden" name="pageId" value="@page2.Id" />
                                <input type="hidden" name="projectId" value="@Model.Id" />
                                <div class="modal-header">
                                    <h5 class="modal-title">New Section</h5>
                                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                                </div>
                                <div class="modal-body">
                                    <div class="mb-3">
                                        <label class="form-label">Section Name</label>
                                        <input type="text" class="form-control" name="name"
                                               placeholder="e.g. Hero" required autofocus />
                                    </div>
                                </div>
                                <div class="modal-footer">
                                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                                    <button type="submit" class="btn btn-primary">Create Section</button>
                                </div>
                            </form>
                        </div>
                    </div>
                </div>
            }
        </div>
    </div>
</div>

<!-- Rename Page Modal -->
<div class="modal fade" id="renamePageModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-sm">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Rename Page</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <input type="text" class="form-control" id="renamePageInput" placeholder="Page title" />
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-primary" id="renamePageSaveBtn">Save</button>
            </div>
        </div>
    </div>
</div>

<!-- Image Select Modal -->
<div class="modal fade" id="imageSelectModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-lg">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Select Image</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="modalAssetUploadInput" class="form-label fw-bold">Upload New Photo</label>
                    <input class="form-control" type="file" id="modalAssetUploadInput" accept="image/*">
                </div>
                <hr />
                <h6>Your Gallery</h6>
                <div id="modalAssetList" class="d-flex flex-wrap gap-3 mt-3">
                    <!-- Assets will be loaded here -->
                </div>
            </div>
        </div>
    </div>
</div>

<!-- Button Link Modal -->
<div class="modal fade" id="linkModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog">
        <div class="modal-content">
            <div class="modal-header">
                <h5 class="modal-title">Edit Link</h5>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
            </div>
            <div class="modal-body">
                <div class="mb-3">
                    <label for="linkText" class="form-label">Link Text</label>
                    <input type="text" class="form-control" id="linkText" placeholder="Button Label">
                </div>
                <hr />
                <div class="mb-3">
                    <label for="linkPage" class="form-label">Internal Page</label>
                    <select class="form-select" id="linkPage">
                        <option value="">-- External URL or Custom Path --</option>
                        @foreach (var pageDto in Model.PageDtos)
                        {
                            <option value="@pageDto.Path">@pageDto.Title (@pageDto.Path)</option>
                        }
                    </select>
                </div>
                <div class="mb-3">
                    <label for="linkHref" class="form-label">URL / Link</label>
                    <input type="text" class="form-control" id="linkHref" placeholder="https://example.com or #section">
                </div>
                <div class="mb-3">
                    <div class="form-check">
                        <input class="form-check-input" type="checkbox" id="linkTargetBlank">
                        <label class="form-check-label" for="linkTargetBlank">
                            Open in new tab
                        </label>
                    </div>
                </div>
            </div>
            <div class="modal-footer">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                <button type="button" class="btn btn-danger d-none" id="removeLinkBtn">Remove Link</button>
                <button type="button" class="btn btn-primary" id="applyLinkBtn">Apply Link</button>
            </div>
        </div>
    </div>
</div>

<!-- Image Lightbox Modal -->
<div class="modal fade" id="lightboxModal" tabindex="-1" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered">
        <div class="modal-content bg-dark border-0">
            <div class="modal-body p-0 text-center position-relative">
                <button type="button" class="btn-close btn-close-white position-absolute top-0 end-0 m-3" data-bs-dismiss="modal" aria-label="Close"></button>
                <img id="lightboxImage" src="" class="img-fluid" style="max-height: 80vh;">
                <div class="p-3 text-white bg-black bg-opacity-75">
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span id="lightboxCaption" class="small"></span>
                        <div class="d-flex gap-2">
                             <button type="button" class="btn btn-sm btn-outline-light" id="changeImageBtn">Change Photo</button>
                             <button type="button" class="btn btn-sm btn-primary" id="saveResizeBtn">Apply Size</button>
                        </div>
                    </div>
                    <div class="row align-items-center g-2">
                        <div class="col-auto"><small>Width</small></div>
                        <div class="col">
                            <input type="range" class="form-range" id="imageWidthRange" min="10" max="100" step="1">
                        </div>
                        <div class="col-auto text-end" style="min-width: 45px;"><small id="imageWidthVal">100%</small></div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .section-drop-zone.drag-over {
        outline: 2px dashed #0d6efd;
        background-color: #e9f0ff !important;
    }
    .border-dashed { border-style: dashed !important; }
    [data-text-editable]:focus { outline: 2px solid #0d6efd; border-radius: 2px; }
    [data-text-editable]:hover { outline: 1px dashed #adb5bd; border-radius: 2px; cursor: text; }
    .component-editable {
        min-height: 50px;
        position: relative;
    }
    .nav-link:not(.active) ~ .page-delete-form { display: none !important; }
    
    .asset-item-container { position: relative; display: inline-block; }
    .asset-item { width: 60px; height: 60px; object-fit: cover; cursor: pointer; border: 2px solid transparent; border-radius: 4px; transition: border-color 0.2s, transform 0.2s, outline 0.2s; }
    .modal-asset-item { width: 120px; height: 120px; object-fit: cover; cursor: pointer; border: 3px solid transparent; border-radius: 8px; transition: transform 0.2s, border-color 0.2s, outline 0.2s; }
    
    .delete-asset-btn { 
        position: absolute; top: -5px; right: -5px; 
        width: 18px; height: 18px; line-height: 16px; 
        font-size: 12px; padding: 0; border-radius: 50%; 
        display: none; z-index: 5;
    }
    .asset-item-container:hover .delete-asset-btn { display: block; }
    
    .component-editable img:hover { outline: 3px solid #0d6efd; transform: scale(1.01); }
    .asset-item:hover, .modal-asset-item:hover { transform: scale(1.05); outline: 3px solid #0d6efd; border-color: transparent; }

    /* Visual indicator for linkable elements in builder */
    .component-editable a:hover, 
    .component-editable .btn:hover, 
    .component-editable button:hover { 
        outline: 2px dashed #0d6efd; 
        outline-offset: 2px;
        cursor: pointer;
    }

    #lightboxImage { cursor: zoom-out; }
</style>

<script src="~/js/builder/builder-core.js"></script>
<script src="~/js/builder/builder-dragdrop.js"></script>
<script src="~/js/builder/builder-editing.js"></script>
<script src="~/js/builder/builder-assets.js"></script>
<script src="~/js/builder/builder-modals.js"></script>
<script src="~/js/builder/builder-pages.js"></script>

<script>
    // Initialize builder with server-side data
    builder.init({
        projectId: '@Model.Id',
        activeTab: '@Html.Raw(Model.ActiveTab)'
    });

    // Publish / Unpublish
    (function () {
        var token = document.querySelector('input[name="__RequestVerificationToken"]')?.value;

        function togglePublish(action, btn) {
            var projectId = btn.dataset.projectId;
            btn.disabled = true;
            fetch('/WebsiteProject/' + action + '/' + projectId, {
                method: 'POST',
                headers: { 'RequestVerificationToken': token }
            })
            .then(r => r.json())
            .then(function (data) {
                if (data.success) location.reload();
                else btn.disabled = false;
            })
            .catch(function () { btn.disabled = false; });
        }

        var publishBtn = document.getElementById('publish-btn');
        var unpublishBtn = document.getElementById('unpublish-btn');

        if (publishBtn) publishBtn.addEventListener('click', function () { togglePublish('Publish', this); });
        if (unpublishBtn) unpublishBtn.addEventListener('click', function () { togglePublish('Unpublish', this); });
    })();
</script>