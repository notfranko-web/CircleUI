@model IEnumerable<CircleUI.Data.Models.User>

@{
    ViewData["Title"] = "Users";
    Layout = "_Layout";
}

<h1>Users</h1>

<a asp-action="Create" class="btn btn-primary mb-3">Create New User</a>

<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Display Name</th>
            <th>User Name</th>
            <th>Email</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in Model)
        {
            <tr>
                <td>@user.Id</td>
                <td>@user.DisplayName</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    <a asp-action="Details" asp-route-id="@user.Id" class="btn btn-sm btn-info">Details</a>
                    <a asp-action="Edit" asp-route-id="@user.Id" class="btn btn-sm btn-warning">Edit</a>
                    <a asp-action="Delete" asp-route-id="@user.Id" class="btn btn-sm btn-danger">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>
