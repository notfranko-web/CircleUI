@model CircleUI.ViewModels.Page.PageDetailsViewModel

@{
    ViewData["Title"] = "Page Details";
}

<h1>Page Details</h1>

<div>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">Title</dt>
        <dd class="col-sm-10">@Model.Title</dd>

        <dt class="col-sm-2">Path</dt>
        <dd class="col-sm-10">@Model.Path</dd>

        <dt class="col-sm-2">Meta Description</dt>
        <dd class="col-sm-10">@Model.MetaDescription</dd>

        <dt class="col-sm-2">Meta Keywords</dt>
        <dd class="col-sm-10">@Model.MetaKeywords</dd>

        <dt class="col-sm-2">Project Id</dt>
        <dd class="col-sm-10">@Model.ProjectId</dd>
    </dl>
</div>
<div>
    <a asp-action="Edit" asp-route-id="@Model.Id" class="btn btn-warning">Edit</a>
    <a asp-action="Index" class="btn btn-secondary">Back to List</a>
</div>
