@model CircleUI.ViewModels.Asset.AssetDetailsViewModel

@{
    ViewData["Title"] = "Delete Asset";
}

<h1>Delete Asset</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Asset Details</h4>
    <hr />
    <dl class="row">
        <dt class="col-sm-2">Id</dt>
        <dd class="col-sm-10">@Model.Id</dd>

        <dt class="col-sm-2">File Name</dt>
        <dd class="col-sm-10">@Model.FileName</dd>

        <dt class="col-sm-2">Mime Type</dt>
        <dd class="col-sm-10">@Model.MimeType</dd>

        <dt class="col-sm-2">Size Bytes</dt>
        <dd class="col-sm-10">@Model.SizeBytes</dd>

        <dt class="col-sm-2">Storage Path</dt>
        <dd class="col-sm-10">@Model.StoragePath</dd>

        <dt class="col-sm-2">User Id</dt>
        <dd class="col-sm-10">@Model.UserId</dd>
    </dl>

    <form asp-action="Delete" method="post">
        <input type="hidden" asp-for="Id" />
        <button type="submit" class="btn btn-danger">Delete</button>
        <a asp-action="Index" class="btn btn-secondary">Cancel</a>
    </form>
</div>
