@model CircleUI.ViewModels.Asset.AssetUpdateViewModel

@{
    ViewData["Title"] = "Edit Asset";
}

<h1>Edit Asset</h1>

<form asp-action="Update" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group mb-3">
        <label asp-for="FileName" class="form-label"></label>
        <input asp-for="FileName" class="form-control" />
        <span asp-validation-for="FileName" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="MimeType" class="form-label"></label>
        <input asp-for="MimeType" class="form-control" />
        <span asp-validation-for="MimeType" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="SizeBytes" class="form-label"></label>
        <input asp-for="SizeBytes" class="form-control" type="number" />
        <span asp-validation-for="SizeBytes" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="StoragePath" class="form-label"></label>
        <input asp-for="StoragePath" class="form-control" />
        <span asp-validation-for="StoragePath" class="text-danger"></span>
    </div>

    <div class="form-group mb-3">
        <label asp-for="UserId" class="form-label"></label>
        <input asp-for="UserId" class="form-control" />
        <span asp-validation-for="UserId" class="text-danger"></span>
    </div>

    <button type="submit" class="btn btn-primary">Update</button>
    <a asp-action="Index" class="btn btn-secondary">Cancel</a>
</form>
