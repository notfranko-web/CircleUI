@using CircleUI.Data.Models
@{
    ViewData["Title"] = "Admin Panel";
    var users = (List<User>)ViewBag.Users;
    var userRoles = (Dictionary<string, bool>)ViewBag.UserRoles;
}

<h1>Admin Panel</h1>

<div class="row g-3 mb-4">
    <div class="col-sm-4">
        <div class="admin-stat-card">
            <div class="admin-stat-value">@ViewBag.UserCount</div>
            <div class="admin-stat-label">Users</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="admin-stat-card">
            <div class="admin-stat-value">@ViewBag.ComponentCount</div>
            <div class="admin-stat-label">Components</div>
        </div>
    </div>
    <div class="col-sm-4">
        <div class="admin-stat-card">
            <div class="admin-stat-value">@ViewBag.AssetCount</div>
            <div class="admin-stat-label">Assets</div>
        </div>
    </div>
</div>
@Html.AntiForgeryToken()
<input type="file" id="adminAssetFileInput" accept="image/*,video/*,audio/*,.pdf,.svg" style="display:none">

<div class="d-flex gap-2 mb-4">
    <a asp-controller="Component" asp-action="Index" class="btn btn-primary">Manage Components</a>
    <a asp-controller="Asset" asp-action="Index" class="btn btn-primary">Manage Assets</a>
    <a asp-controller="Component" asp-action="Create" class="btn btn-secondary">New Component</a>
    <button type="button" class="btn btn-secondary" id="adminUploadBtn">
        <i class="bi bi-upload me-1"></i> Upload Asset
    </button>
</div>
<div id="adminUploadStatus" class="mb-3" style="display:none"></div>

<h2>User Management</h2>

<table class="table">
    <thead>
        <tr>
            <th>Display Name</th>
            <th>Username</th>
            <th>Email</th>
            <th>Role</th>
            <th>Actions</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var user in users)
        {
            var isAdmin = userRoles[user.Id];
            <tr>
                <td>@user.DisplayName</td>
                <td>@user.UserName</td>
                <td>@user.Email</td>
                <td>
                    @if (isAdmin)
                    {
                        <span class="badge-admin">Admin</span>
                    }
                    else
                    {
                        <span class="badge-user">User</span>
                    }
                </td>
                <td>
                    @if (!isAdmin)
                    {
                        <form asp-action="MakeAdmin" method="post" style="display:inline">
                            <input type="hidden" name="userId" value="@user.Id"/>
                            <button type="submit" class="btn btn-sm btn-success">Make Admin</button>
                        </form>
                    }
                    else if (user.Email != "admin@circleui.com")
                    {
                        <form asp-action="RemoveAdmin" method="post" style="display:inline">
                            <input type="hidden" name="userId" value="@user.Id"/>
                            <button type="submit" class="btn btn-sm btn-danger">Remove Admin</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted" style="font-size:.8rem">Protected</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
<script>
    const adminUploadBtn   = document.getElementById('adminUploadBtn');
    const adminFileInput   = document.getElementById('adminAssetFileInput');
    const adminStatus      = document.getElementById('adminUploadStatus');
    const token            = document.querySelector('input[name="__RequestVerificationToken"]').value;

    adminUploadBtn.addEventListener('click', () => adminFileInput.click());

    adminFileInput.addEventListener('change', async () => {
        const file = adminFileInput.files[0];
        if (!file) return;

        adminStatus.style.display = '';
        adminStatus.innerHTML = '<span class="text-muted">Uploading…</span>';
        adminUploadBtn.disabled = true;

        const form = new FormData();
        form.append('file', file);

        const res = await fetch('/Asset/Upload', {
            method: 'POST',
            headers: { 'RequestVerificationToken': token },
            body: form
        });

        const data = await res.json();
        if (data.success) {
            adminStatus.innerHTML = '<span class="text-success">Upload successful!</span>';
        } else {
            adminStatus.innerHTML = `<span class="text-danger">Upload failed: ${data.message}</span>`;
        }

        adminUploadBtn.disabled = false;
        adminFileInput.value = '';
    });
</script>
}
